# ─── App ───
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ───
DATABASE_URL="postgresql://postgres:password@localhost:5432/remont_india?schema=public"

# ─── Redis (real-time + caching) ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───
JWT_SECRET=replace-with-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another-long-random-string-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── SMS/WhatsApp (MSG91) ───
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_OTP_TEMPLATE_ID=your-template-id
MSG91_SENDER_ID=RMNTIN

# ─── Razorpay ───
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── Cloudinary (image storage) ───
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── AI Provider (when LLM swap-in) ───
AI_PROVIDER=RULE_BASED
# Or: OPENAI / ANTHROPIC
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# ─── Admin defaults ───
ADMIN_DEFAULT_PHONE=+919876543210
ADMIN_DEFAULT_EMAIL=admin@remontindia.com

# ─── Webhooks for CRM integrations ───
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
