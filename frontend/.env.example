# ─── Frontend Environment (local development only) ───────────────────────────
# In production, Vercel rewrites /api/* to the Railway backend.
# No env vars are injected into the static HTML at runtime.
# This file is documentation only — copy to .env for local tooling if needed.

# Backend base URL used by the API script in index.html (local dev)
# In production this is empty-string (relative URL) — Vercel rewrite handles routing.
API_BASE_URL=http://localhost:3001
